#!/usr/bin/env python3

# Click uses decorators to define commands, handles argument parsing,
# type validation, and generates --help text automatically.

import os
import signal
import subprocess
from pathlib import Path

import click

import tunnel

__version__ = "0.0.7"

SCRIPT_DIR = Path(__file__).resolve().parent
PID_FILE = SCRIPT_DIR / "pod.pid"

VENV = SCRIPT_DIR / ".venv" / "bin" / "python"
FILE_PATH = SCRIPT_DIR / "server.py"


# Helper functions


# helper function to a helper function (start server: check if running)
def _is_server_running():
    """Check if server is already running."""
    if not PID_FILE.exists():
        return False
    pid = int(PID_FILE.read_text())
    try:
        os.kill(pid, 0)  # Check if process exists
        return True
    except ProcessLookupError:
        PID_FILE.unlink()  # Clean up stale PID file
        return False


def _do_start(port=None):
    """Start the server in HTTP mode."""
    if _is_server_running():
        click.secho("Server is already running.", fg="yellow")
        return

    if port is None:
        port = 8000

    click.secho(f"Starting HTTP server on port {port}...", fg="blue")
    proc = subprocess.Popen(
        [str(VENV), str(FILE_PATH), "--http", f"--port={port}"],
    )
    PID_FILE.write_text(str(proc.pid))
    click.echo(f"Server started (PID: {proc.pid})")


def _do_stop():
    """Stop the server."""
    if PID_FILE.exists():
        pid = int(PID_FILE.read_text())
        try:
            os.kill(pid, signal.SIGTERM)
            click.echo("Server stopped.")
        except ProcessLookupError:
            click.echo("Server was not running (stale PID file).")
        PID_FILE.unlink()
    else:
        click.echo("No server is running.")


@click.group()
@click.version_option(__version__, prog_name="pod")
def cli():
    """A CLI tool for managing LLM memory server, PODs"""
    pass


# Register tunnel commands
tunnel.register(cli)


@cli.command()
def completion():
    """Show shell completion setup instructions."""
    shell = os.environ.get("SHELL", "")
    if "zsh" in shell:
        click.echo("Add to ~/.zshrc:")
        click.secho('eval "$(_POD_COMPLETE=zsh_source pod)"', fg="green")
    elif "fish" in shell:
        click.echo("Add to ~/.config/fish/completions/pod.fish:")
        click.secho('eval (env _POD_COMPLETE=fish_source pod)', fg="green")
    elif "bash" in shell:
        click.echo("Add to ~/.bashrc:")
        click.secho('eval "$(_POD_COMPLETE=bash_source pod)"', fg="green")
    else:
        click.secho(f"Unknown shell: {shell}. Manually add completion for your shell.", fg="red")


@cli.command()
def status():
    """Check the status of the pod."""
    # check systemd service first
    result = subprocess.run("systemctl --user is-active pods 2>/dev/null", shell=True, capture_output=True, text=True)
    if result.stdout.strip() == "active":
        click.secho("Server is running (systemd).", fg="green")
        # show PID
        result = subprocess.run("systemctl --user show pods --property=MainPID --value", shell=True, capture_output=True, text=True)
        if result.stdout.strip() and result.stdout.strip() != "0":
            click.echo(f"PID: {result.stdout.strip()}")
        return

    # fall back to PID file check
    if PID_FILE.exists():
        pid = int(PID_FILE.read_text())
        try:
            os.kill(pid, 0)
            click.secho("Server is running.", fg="green")
            click.echo(f"PID: {pid}")
        except ProcessLookupError:
            click.secho("Server is NOT running (stale PID file).", fg="red")
            PID_FILE.unlink()
    else:
        click.secho("Server is NOT running.", fg="red")


@cli.command()
def doctor():
    """Check if pod is correctly installed."""
    # check symlink
    global_path = "/usr/local/bin/pod"
    user_path = Path.home() / ".local" / "bin" / "pod"

    issues = []

    if Path(global_path).exists():
        target = os.readlink(global_path)
        if not Path(target).exists():
            issues.append(f"Symlink broken: {global_path} -> {target}")
        else:
            click.secho(f"Global symlink OK: {global_path} -> {target}", fg="green")
    elif user_path.exists():
        target = os.readlink(str(user_path))
        if not Path(target).exists():
            issues.append(f"Symlink broken: {user_path} -> {target}")
        else:
            click.secho(f"User symlink OK: {user_path} -> {target}", fg="green")
    else:
        issues.append("No symlink found. Run: pod server install")

    # check venv
    if VENV.exists():
        click.secho(f"Venv OK: {VENV}", fg="green")
    else:
        issues.append(f"Venv not found: {VENV}")

    # check server.py
    if FILE_PATH.exists():
        click.secho(f"Server OK: {FILE_PATH}", fg="green")
    else:
        issues.append(f"Server not found: {FILE_PATH}")

    if issues:
        click.secho("\nIssues found:", fg="red")
        for issue in issues:
            click.echo(f"  - {issue}")
    else:
        click.secho("\nAll checks passed!", fg="green")


@cli.group()
def server():
    """Server management (start (--local, --port), stop, restart)."""
    pass


# ./pod server start
@server.command()
@click.option("--local", is_flag=True, help="Run in local mode (stdio)")
@click.option("--port", type=int, help="Port to listen on")
def start(local, port):
    """Start the server (local or HTTP mode)."""
    if local:
        click.secho("Starting in local mode (stdio)...", fg="green")
        click.echo("\n In the config, add the following command to run in local mode:")
        click.secho("pod server --local", fg="black", bg="green")
        click.echo("Running in local mode...")
        os.execv(str(VENV), [str(VENV), str(FILE_PATH)])
    else:
        _do_start(port)


# ./pod server stop
@server.command()
def stop():
    """Stop the server."""
    _do_stop()


# ./pod server logs
@click.option("-n", "--lines", default=20, help="Number of log lines to show")
@server.command()
def logs(lines):
    """Tail server logs (systemd journal)."""
    # detect scope
    result = subprocess.run(
        'if [ -f ~/.config/systemd/user/pods.service ]; then echo "local"; elif [ -f /etc/systemd/system/pods.service ]; then echo "global"; fi',
        shell=True, capture_output=True, text=True
    )
    scope = result.stdout.strip()
    if scope == "local":
        subprocess.run(f"journalctl --user -u pods -n {lines} --no-pager", shell=True)
    elif scope == "global":
        subprocess.run(f"sudo journalctl -u pods -n {lines} --no-pager", shell=True)
    else:
        click.secho("No service found. Logs available at: server.log (if running manually)", fg="yellow")


# ./pod server restart
@server.command()
@click.option("--port", type=int, default=8000, help="Port to listen on")
def restart(port):
    """Restart the server."""
    _do_stop()
    _do_start(port)


# ./pod server install
@server.command()
def install():
    """Install as systemd service and symlink pod command."""
    # check if already installed
    local_service = Path.home() / ".config" / "systemd" / "user" / "pods.service"
    global_service = Path("/etc/systemd/system/pods.service")
    local_symlink = Path.home() / ".local" / "bin" / "pod"
    global_symlink = Path("/usr/local/bin/pod")

    already_installed = local_service.exists() or global_service.exists() or local_symlink.exists() or global_symlink.exists()
    if already_installed:
        click.secho("Already installed.", fg="yellow")
        if not click.confirm("Reinstall?"):
            return

    scope = click.prompt("Install scope", type=click.Choice(["local", "global"]))

    if scope == "local":
        service_dir = "~/.config/systemd/user"
        sudo = ""
        systemctl = "systemctl --user"
        bin_dir = str(Path.home() / ".local" / "bin")
    else:
        service_dir = "/etc/systemd/system"
        sudo = "sudo "
        systemctl = "sudo systemctl"
        bin_dir = "/usr/local/bin"

    try:
        # symlink pod command
        subprocess.run(f"{sudo}mkdir -p {bin_dir}", shell=True, check=True)
        subprocess.run(f"{sudo}ln -sf {SCRIPT_DIR / 'pod'} {bin_dir}/pod", shell=True, check=True)
        click.secho(f"pod linked to {bin_dir}/pod", fg="green")

        # install service (replace placeholders with actual paths)
        subprocess.run(f"{sudo}mkdir -p {service_dir}", shell=True, check=True)
        service_content = (SCRIPT_DIR / "pods.service").read_text()
        service_content = service_content.replace("PYTHON_PLACEHOLDER", str(VENV))
        service_content = service_content.replace("WorkingDirectory=%h/pods", f"WorkingDirectory={SCRIPT_DIR}")
        if sudo:
            subprocess.run(f"echo {repr(service_content)} | sudo tee {service_dir}/pods.service > /dev/null", shell=True, check=True)
        else:
            service_file = Path(service_dir).expanduser() / "pods.service"
            service_file.write_text(service_content)
        subprocess.run(f"{systemctl} daemon-reload", shell=True, check=True)

        # add shell completion
        shell = os.environ.get("SHELL", "")
        if "zsh" in shell:
            rc_file = Path.home() / ".zshrc"
            completion_line = 'eval "$(_POD_COMPLETE=zsh_source pod)"'
        elif "fish" in shell:
            rc_file = Path.home() / ".config" / "fish" / "completions" / "pod.fish"
            completion_line = "_POD_COMPLETE=fish_source pod > " + str(rc_file)
        else:
            rc_file = Path.home() / ".bashrc"
            completion_line = 'eval "$(_POD_COMPLETE=bash_source pod)"'

        # only add if not already present
        if rc_file.exists() and completion_line in rc_file.read_text():
            click.secho("Shell completion already configured.", fg="green")
        else:
            with open(rc_file, "a") as f:
                f.write(f"\n# pods CLI completion\n{completion_line}\n")
            click.secho(f"Shell completion added to {rc_file}", fg="green")
    except subprocess.CalledProcessError as e:
        click.secho(f"Install failed: {e}", fg="red")
        return

    if click.confirm("Enable and start the service now?"):
        subprocess.run(f"{systemctl} enable --now pods", shell=True, check=True)
        click.secho("Service enabled and started.", fg="green")
    else:
        click.echo(f"Service installed. Run: {systemctl} enable --now pods")


# ./pod server uninstall
@server.command()
def uninstall():
    """Remove systemd service and pod symlink."""
    result = subprocess.run(
        'if [ -f ~/.config/systemd/user/pods.service ]; then echo "local"; elif [ -f /etc/systemd/system/pods.service ]; then echo "global"; fi',
        shell=True, capture_output=True, text=True
    )
    scope = result.stdout.strip()

    if not scope:
        click.secho("No service found.", fg="yellow")
        return

    try:
        if scope == "local":
            subprocess.run("systemctl --user stop pods 2>/dev/null", shell=True, capture_output=True)
            subprocess.run("systemctl --user disable pods 2>/dev/null", shell=True, capture_output=True)
            subprocess.run("rm -f ~/.config/systemd/user/pods.service", shell=True, check=True)
            subprocess.run("systemctl --user daemon-reload 2>/dev/null", shell=True, capture_output=True)
            subprocess.run("rm -f ~/.local/bin/pod", shell=True, check=True)
        else:
            subprocess.run("sudo systemctl stop pods 2>/dev/null", shell=True, capture_output=True)
            subprocess.run("sudo systemctl disable pods 2>/dev/null", shell=True, capture_output=True)
            subprocess.run("sudo rm -f /etc/systemd/system/pods.service", shell=True, check=True)
            subprocess.run("sudo systemctl daemon-reload 2>/dev/null", shell=True, capture_output=True)
            subprocess.run("sudo rm -f /usr/local/bin/pod", shell=True, check=True)

        # remove shell completion
        shell = os.environ.get("SHELL", "")
        if "zsh" in shell:
            rc_file = Path.home() / ".zshrc"
        elif "fish" not in shell:
            rc_file = Path.home() / ".bashrc"
        else:
            rc_file = None

        if rc_file and rc_file.exists():
            lines = rc_file.read_text().splitlines()
            filtered = [l for l in lines if "# pods CLI completion" not in l and "_POD_COMPLETE" not in l]
            rc_file.write_text("\n".join(filtered) + "\n")
            click.secho(f"Shell completion removed from {rc_file}", fg="green")

        click.secho(f"Service uninstalled ({scope}).", fg="green")
    except subprocess.CalledProcessError as e:
        click.secho(f"Uninstall failed: {e}", fg="red")


# main function
if __name__ == "__main__":
    cli()
